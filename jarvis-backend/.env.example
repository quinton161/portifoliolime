# Copy to ".env" in this folder (never commit real secrets).

# Required for GPT-powered replies (server-side only — never put this in the React .env with REACT_APP_).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Default model: gpt-4o (strong general model). For maximum capability / cost, try gpt-4-turbo or o1 (if your account has access).
OPENAI_MODEL=gpt-4o

# Optional: comma-separated origins for browser requests (default * is fine for local dev).
# Production example:
# CORS_ORIGINS=https://your-site.vercel.app,https://www.yourdomain.com

# Optional n8n automation webhook (keyword-triggered messages only).
# N8N_WEBHOOK_URL=
