# Copy to ".env" in this folder, fill in values, restart `npm start` / rebuild.
# Never commit real keys — .env should stay gitignored.

# --- Recommended for production (API keys stay on the server) ---
# Deploy jarvis-backend and set OPENAI_API_KEY / OPENAI_MODEL there, then point the site here (no trailing slash).
# Local dev uses http://127.0.0.1:8000 automatically when this is unset.
# REACT_APP_ASSISTANT_API_URL=https://your-api.example.com

# --- Free-tier LLM keys in the browser (pick one; keys are inlined in the bundle — prefer backend above) ---
# Google AI Studio (free): https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=
REACT_APP_GEMINI_MODEL=gemini-2.0-flash

# Groq (free tier, fast): https://console.groq.com/keys
REACT_APP_GROQ_API_KEY=
REACT_APP_GROQ_MODEL=llama-3.3-70b-versatile

# Optional paid fallback — OpenAI in browser (dev / quick test; not ideal for production)
REACT_APP_OPENAI_API_KEY=
REACT_APP_OPENAI_MODEL=gpt-4o-mini

# Which provider: auto (Gemini → Groq → OpenAI) | gemini | groq | openai
# REACT_APP_LLM_PROVIDER=auto

# Optional: deployed FastAPI alias
# REACT_APP_JARVIS_API_URL=

# Contact form — https://web3forms.com
# Production: set on Vercel and redeploy (CRA inlines at build time).
# Without a key, submit falls back to the visitor's mail app.
REACT_APP_WEB3FORMS_ACCESS_KEY=
