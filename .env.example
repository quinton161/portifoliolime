# Copy to ".env" in this folder, fill in values, restart `npm start` / rebuild.
# Never commit real keys — .env should stay gitignored.

# --- Portfolio assistant (recommended for production) ---
# Deploy jarvis-backend (Railway, Render, Fly.io, etc.) and paste its public URL (no trailing slash).
# On that server set OPENAI_API_KEY and OPENAI_MODEL — keys stay on the server, not in the browser bundle.
# REACT_APP_ASSISTANT_API_URL=https://your-api.example.com

# --- Optional: browser-only OpenAI (dev / quick test — exposes key in the built JS; not recommended for production) ---
# REACT_APP_OPENAI_API_KEY=
# REACT_APP_OPENAI_MODEL=gpt-4o-mini

# Optional: deployed FastAPI alias
# REACT_APP_JARVIS_API_URL=

# Contact form — https://web3forms.com
# Production: set on Vercel and redeploy (CRA inlines at build time).
# Without a key, submit falls back to the visitor's mail app.
REACT_APP_WEB3FORMS_ACCESS_KEY=
